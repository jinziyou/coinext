# Coinext environment. Copy to `.env` and fill in. Config precedence:
#   CLI flags > env (COINEXT__SECTION__KEY) > config/*.yaml files > built-in defaults.
# Double-underscore separates nested config sections, e.g. COINEXT__RISK__MAX_ORDERS_PER_SEC.

# --- Environment selection ---
COINEXT__ENV=backtest                    # backtest | sandbox | live

# --- Binance (reference adapter) ---
# Public market-data streams need no keys. Trading (sandbox/live) does.
COINEXT__BINANCE__API_KEY=
COINEXT__BINANCE__API_SECRET=
COINEXT__BINANCE__TESTNET=true            # true -> sandbox endpoints (testnet)

# --- Infrastructure ---
COINEXT__REDIS__URL=redis://redis:6379/0
COINEXT__POSTGRES__DSN=postgresql://coinext:coinext@postgres:5432/coinext
COINEXT__MINIO__ENDPOINT=http://minio:9000
COINEXT__MINIO__ACCESS_KEY=coinext
COINEXT__MINIO__SECRET_KEY=coinext-secret
COINEXT__DATA__LAKE_ROOT=/data

# --- Risk (defense-in-depth; the per-order RiskEngine reads these too) ---
COINEXT__RISK__MAX_ORDER_NOTIONAL=50000
COINEXT__RISK__MAX_POSITION_NOTIONAL=250000
COINEXT__RISK__MAX_GROSS_EXPOSURE=1000000
COINEXT__RISK__MAX_ORDERS_PER_SEC=20
COINEXT__RISK__KILL_SWITCH=false

# --- Observability ---
COINEXT__OTEL__ENDPOINT=http://otel-collector:4317
COINEXT__LOG__LEVEL=info

# --- API / UI ---
COINEXT__API__HOST=0.0.0.0
COINEXT__API__PORT=8000
# Shared secret required in the `X-API-Key` header for mutating/control endpoints
# (POST /backtest, POST/ /control/*). Unset -> those endpoints fail closed (HTTP 503).
COINEXT__API__KEY=
# Comma-separated allowed CORS origins for the browser UI. Empty -> no cross-origin access
# (never defaults to "*").
COINEXT__API__CORS_ORIGINS=http://localhost:5173
COINEXT__UI__API_BASE=http://localhost:8000
