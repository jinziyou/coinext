# VeloxQuant environment. Copy to `.env` and fill in. Config precedence:
#   CLI flags > env (VQ__SECTION__KEY) > config/*.yaml files > built-in defaults.
# Double-underscore separates nested config sections, e.g. VQ__RISK__MAX_ORDERS_PER_SEC.

# --- Environment selection ---
VQ__ENV=backtest                    # backtest | sandbox | live

# --- Binance (reference adapter) ---
# Public market-data streams need no keys. Trading (sandbox/live) does.
VQ__BINANCE__API_KEY=
VQ__BINANCE__API_SECRET=
VQ__BINANCE__TESTNET=true            # true -> sandbox endpoints (testnet)

# --- Infrastructure ---
VQ__REDIS__URL=redis://redis:6379/0
VQ__POSTGRES__DSN=postgresql://veloxquant:veloxquant@postgres:5432/veloxquant
VQ__MINIO__ENDPOINT=http://minio:9000
VQ__MINIO__ACCESS_KEY=veloxquant
VQ__MINIO__SECRET_KEY=veloxquant-secret
VQ__DATA__LAKE_ROOT=/data

# --- Risk (defense-in-depth; the per-order RiskEngine reads these too) ---
VQ__RISK__MAX_ORDER_NOTIONAL=50000
VQ__RISK__MAX_POSITION_NOTIONAL=250000
VQ__RISK__MAX_GROSS_EXPOSURE=1000000
VQ__RISK__MAX_ORDERS_PER_SEC=20
VQ__RISK__KILL_SWITCH=false

# --- Observability ---
VQ__OTEL__ENDPOINT=http://otel-collector:4317
VQ__LOG__LEVEL=info

# --- API / UI ---
VQ__API__HOST=0.0.0.0
VQ__API__PORT=8000
VQ__UI__API_BASE=http://localhost:8000
